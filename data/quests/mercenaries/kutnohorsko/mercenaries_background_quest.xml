                <IfFunction Name="reset_loop" PositionY="-1000" PositionX="300" MethodName="Control::Compare" DeclaringType="Control" TypeT="int">
                    <Constant Name="Op" Value="Greater" />
                    <Constant Name="ValueB" Value="0" />
                    <Edge From="injured_mercs_count.State" To="ValueA" />
                    <Edge From="dismissal_dialog.mercenary_open_heal_menu" To="Exec" />
                    <Edge From="injured_mercs_count.OnDecrease" To="Exec" />
                </IfFunction>

                <State Name="injured_mercs_count" PositionY="-800" PositionX="600" TypeT="int">
                    <Edge From="check_injured.True" To="Increment" />
                    <Edge From="reset_loop.True" To="Decrement" />
                </State>

                <ForEach Name="scan_mercs" PositionY="-400" PositionX="-300" TypeT="wh::rpgmodule::Souls">
                    <Asset Name="Array" Alias="mercs" />
                    <Edge From="reset_loop.False" To="Begin" />
                </ForEach>

                <MemberFunction Name="get_health" PositionY="-200" PositionX="-50" MethodName="GetState" DeclaringType="wh::rpgmodule::I_Soul">
                    <Constant Name="State" Value="health" />
                    <Edge From="scan_mercs.Value" To="Soul" />
                </MemberFunction>

                <IfFunction Name="check_health" PositionY="-400" PositionX="300" MethodName="Control::Compare" DeclaringType="Control" TypeT="float">
                    <Constant Name="Op" Value="Greater" />
                    <Constant Name="ValueB" Value="0" />
                    <Edge From="scan_mercs.OnValue" To="Exec" />
                    <Edge From="get_health.Value" To="ValueA" />
                </IfFunction>

                <IfFunction Name="check_injured" PositionY="-200" PositionX="600" MethodName="Control::Compare" DeclaringType="Control" TypeT="float">
                    <Constant Name="Op" Value="Less" />
                    <Constant Name="ValueB" Value="80" />
                    <Edge From="check_health.True" To="Exec" />
                    <Edge From="get_health.Value" To="ValueA" />
                </IfFunction>

                <IfFunction Name="has_injured" PositionY="-400" PositionX="900" MethodName="Control::Compare" DeclaringType="Control" TypeT="int">
                    <Constant Name="Op" Value="Greater" />
                    <Constant Name="ValueB" Value="0" />
                    <Edge From="scan_mercs.OnEnd" To="Exec" />
                    <Edge From="injured_mercs_count.State" To="ValueA" />
                </IfFunction>


                <State Name="delivery_lock" PositionY="-600" PositionX="1500" TypeT="bool">
                    <Constant Name="DefaultValue" Value="false" />
                    <Edge From="reset_loop.False" To="SetFalse" />
                    <Edge From="open_ui_if.False" To="SetTrue" />
                </State>

                <ForEach Name="find_target_loop" PositionY="-400" PositionX="1200" TypeT="wh::rpgmodule::Souls">
                    <Asset Name="Array" Alias="mercs" />
                    <Edge From="has_injured.True" To="Begin" />
                </ForEach>

                <MemberFunction Name="get_health_target" PositionY="-200" PositionX="1500" MethodName="GetState" DeclaringType="wh::rpgmodule::I_Soul">
                    <Constant Name="State" Value="health" />
                    <Edge From="find_target_loop.Value" To="Soul" />
                </MemberFunction>

                <IfFunction Name="check_health_target" PositionY="-400" PositionX="1800" MethodName="Control::Compare" DeclaringType="Control" TypeT="float">
                    <Constant Name="Op" Value="Greater" />
                    <Constant Name="ValueB" Value="0" />
                    <Edge From="find_target_loop.OnValue" To="Exec" />
                    <Edge From="get_health_target.Value" To="ValueA" />
                </IfFunction>

                <If Name="open_ui_if" PositionY="-400" PositionX="2100">
                    <Edge From="check_health_target.True" To="Exec" />
                    <Edge From="delivery_lock.State" To="Condition" />
                </If>

                <ObjectProperties Name="alive_merc_props" PositionY="-150" PositionX="2100" DeclaringType="wh::rpgmodule::I_Soul">
                    <Edge From="find_target_loop.Value" To="I_Soul" />
                </ObjectProperties>


                <Function Name="descriptor_food" PositionY="-1000" PositionX="2100" MethodName="wh::entitymodule::CreateItemCategoryDescriptor" DeclaringType="wh::entitymodule">
                    <Constant Name="Category" Value="Food" />
                    <Constant Name="Type" Value="1" />
                    <Edge From="injured_mercs_count.State" To="Amount" />
                </Function>
                
                <Function Name="descriptor_potion" PositionY="-750" PositionX="2100" MethodName="wh::entitymodule::CreateItemCategoryDescriptor" DeclaringType="wh::entitymodule">
                    <Constant Name="Category" Value="Food" />
                    <Constant Name="Type" Value="2" />
                    <Edge From="injured_mercs_count.State" To="Amount" />
                </Function>
                
                <MakeArray Name="descriptors_array" PositionY="-900" PositionX="2500" TypeT="wh::entitymodule::ItemDescriptors">
                    <Edge From="descriptor_food.ItemDescriptor" To="A" />
                    <Edge From="descriptor_potion.ItemDescriptor" To="B" />
                </MakeArray>

                <MakeArray Name="labels_array" PositionY="-700" PositionX="2500" TypeT="wh::framework::LocalizedStrings">
                    <Constant Name="A" Value="ui_mercenary_heal_yourselves" />
                    <Constant Name="B" Value="ui_mercenary_heal_yourselves" />
                </MakeArray>

                <Function Name="create_delivery" PositionY="-300" PositionX="2500" MethodName="wh::entitymodule::CreateItemDelivery" DeclaringType="wh::entitymodule">
                    <Constant Name="DeliveryMode" Value="Any" />
                    <Edge From="descriptors_array.Array" To="DeliveryDescriptors" />
                    <Edge From="descriptors_array.Array" To="PlayerInventoryFilters" />
                    <Edge From="labels_array.Array" To="Labels" />
                    <Edge From="alive_merc_props.Inventory" To="DeliveryInventory" />
                </Function>

                <ItemDeliveryHandler Name="delivery_handler" PositionY="-50" PositionX="2900">
                    <Edge From="open_ui_if.False" To="BeginDelivery" />
                    <Edge From="create_delivery.ItemDelivery" To="ItemDelivery" />
                    <Edge From="compare_result.True" To="AcceptDelivery" />
                    <Edge From="compare_result.False" To="RejectDelivery" />
                </ItemDeliveryHandler>

                <IfFunction Name="compare_result" PositionY="-150" PositionX="3300" TypeT="DeliveryResult" MethodName="Control::Compare" DeclaringType="Control">
                    <Constant Name="Op" Value="Equals" />
                    <Constant Name="ValueB" Value="Success" />
                    <Edge From="delivery_handler.OnResultAvailable" To="Exec" />
                    <Edge From="delivery_handler.DeliveryResult" To="ValueA" />
                </IfFunction>

